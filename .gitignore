# General .gitignore - common patterns for many projects

# ---------- OS ----------
# macOS
.DS_Store
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
.fseventsd/

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------- Editors / IDEs ----------
# Visual Studio Code
.vscode/

# JetBrains (IntelliJ, WebStorm, PyCharm, etc.)
.idea/
*.iml

# Eclipse / NetBeans
.project
.classpath
.settings/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo

# Emacs
*~
.#*

# Backup / temp files
*.bak
*.tmp
*.temp
*.orig

# ---------- Logs ----------
*.log
logs/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ---------- Dependency directories ----------
node_modules/
bower_components/
jspm_packages/
vendor/
.pnp/
.pnpm-store/

# ---------- Build / distribution ----------
dist/
build/
out/
release/
bin/
obj/
target/
coverage/
coverage-reports/

# ---------- Cache / metadata ----------
.cache/
*.cache
.pnp.js
.pnp.cjs
pip-wheel-metadata/
.mypy_cache/
.pytest_cache/

# ---------- Language-specific ----------
# Node
.env.local
.eslintcache

# Python
__pycache__/
*.py[cod]
*.pyd
.Python
venv/
env/
.venv/
env.bak/
*.egg-info/
.eggs/

# Java / JVM
*.class
*.jar
*.war
*.ear
hs_err_pid*.log
.gradle/
build/
target/

# Go
bin/
pkg/
*.test

# Rust
target/
**/*.rlib

# C / C++
*.o
*.obj
*.so
*.a
*.lib
*.dll
*.exe
*.out
CMakeFiles/
CMakeCache.txt
cmake_install.cmake

# .NET
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.pdb

# Ruby / Rails
log/
tmp/
.bundle/
*.gem
coverage/

# PHP / Composer
vendor/
composer.phar

# ---------- Docker ----------
.docker/
docker-compose.override.yml

# ---------- Secrets / environment ----------
.env
.env.*
*.pem
*.key
*.crt
secrets/
credentials/

# ---------- Archives ----------
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# ---------- Wolfram ----------
*.mx
*.wl~
*.nb~

# ---------- Ruliology outputs ----------
data/runs/*
data/metrics/*
data/figures/*
data/exports/*
!data/runs/.gitkeep
!data/metrics/.gitkeep
!data/figures/.gitkeep
!data/exports/.gitkeep
